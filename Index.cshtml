        var printConfirmResolver = null;

        function openPrintConfirmModal(missingList) {
            var modal = document.getElementById('printConfirmModal');
            var msg = document.getElementById('printConfirmMessage');

            if (!modal || !msg) {
                return Promise.resolve(false);
            }

            var text = 'Chưa đủ tên ' + missingList.join(' và ') + '. Bạn có muốn tiếp tục in không?';
            msg.textContent = text;

            modal.style.display = 'flex';
            modal.setAttribute('aria-hidden', 'false');

            return new Promise(function (resolve) {
                printConfirmResolver = resolve;
            });
        }

        function closePrintConfirmModal(result) {
            var modal = document.getElementById('printConfirmModal');
            if (modal) {
                modal.style.display = 'none';
                modal.setAttribute('aria-hidden', 'true');
            }

            if (printConfirmResolver) {
                var resolver = printConfirmResolver;
                printConfirmResolver = null;
                resolver(!!result);
            }
        }

        (function bindPrintConfirmModal() {
            var btnClose = document.getElementById('btnClosePrintConfirm');
            var btnCancel = document.getElementById('btnCancelPrintConfirm');
            var btnContinue = document.getElementById('btnContinuePrintConfirm');
            var modal = document.getElementById('printConfirmModal');

            if (btnClose) {
                btnClose.addEventListener('click', function () {
                    closePrintConfirmModal(false);
                });
            }

            if (btnCancel) {
                btnCancel.addEventListener('click', function () {
                    closePrintConfirmModal(false);
                });
            }

            if (btnContinue) {
                btnContinue.addEventListener('click', function () {
                    closePrintConfirmModal(true);
                });
            }

            if (modal) {
                modal.addEventListener('click', function (e) {
                    if (e.target === modal) {
                        closePrintConfirmModal(false);
                    }
                });
            }

            window.addEventListener('keydown', function (e) {
                var isOpen = modal && modal.style.display === 'flex';
                if (isOpen && e.key === 'Escape') {
                    closePrintConfirmModal(false);
                }
            });
        })();

        document.getElementById('btnPrint').addEventListener('click', async function () {
            var hoiDongText = ((document.getElementById('signHoiDongName') || {}).textContent || '').replace(/\u00A0/g, ' ').trim();
            var bldText = ((document.getElementById('signBanLanhDaoName') || {}).textContent || '').replace(/\u00A0/g, ' ').trim();

            var missing = [];
            if (!hoiDongText) missing.push('Hội đồng');
            if (!bldText) missing.push('Ban lãnh đạo');

            if (missing.length > 0) {
                updatePrintWarnBar();

                var ok = await openPrintConfirmModal(missing);

                if (!ok) {
                    setStatus('warn', 'Đã hủy in vì chưa đủ tên ' + missing.join(' và ') + '.');
                    toastMsg('warn', 'Đã hủy in.');
                    return;
                }

                setStatus('warn', 'Đang in dù chưa đủ tên ' + missing.join(' và ') + '.');
            }

            printOnlyResultArea();
        });



