        function getDateSerial(dateIso) {
            var parts = String(dateIso || '').split('-');
            if (parts.length !== 3) return NaN;
            var y = parseInt(parts[0], 10);
            var m = parseInt(parts[1], 10);
            var d = parseInt(parts[2], 10);
            if (isNaN(y) || isNaN(m) || isNaN(d)) return NaN;
            return Math.floor(Date.UTC(y, m - 1, d) / 86400000);
        }

        function pickHoiDongSignerByDate(list, dateIso) {
            var arr = toArraySafe(list).filter(function (x) { return !!(x || '').trim(); });
            if (!arr.length) return '';
            var serial = getDateSerial(dateIso);
            var base = isNaN(serial) ? getDateSerial(getTodayIso()) : serial;
            var idx = ((base % arr.length) + arr.length) % arr.length;
            return arr[idx];
        }

        function buildHoiDongBalanceHint(list, dateIso) {
            var arr = toArraySafe(list).filter(function (x) { return !!(x || '').trim(); });
            if (!arr.length) return '';
            var parts = String(dateIso || getTodayIso()).split('-');
            if (parts.length !== 3) return '';
            var y = parseInt(parts[0], 10);
            var m = parseInt(parts[1], 10);
            var d = parseInt(parts[2], 10);
            if (isNaN(y) || isNaN(m) || isNaN(d)) return '';

            var target = new Date(y, m - 1, d);
            target.setHours(0, 0, 0, 0);
            var start = new Date(y, 0, 1);
            start.setHours(0, 0, 0, 0);
            var totalDays = Math.floor((target.getTime() - start.getTime()) / 86400000) + 1;
            if (totalDays < 1) totalDays = 1;

            var baseCycles = Math.floor(totalDays / arr.length);
            var remainder = totalDays % arr.length;
            var segments = arr.map(function (name, idx) {
                var extra = idx < remainder ? 1 : 0;
                return name + ': ' + String(baseCycles + extra) + ' ngày';
            });

            return 'Phân bổ đều từ 01/01 đến ' + String(d).padStart(2, '0') + '/' + String(m).padStart(2, '0') + '/' + y + ' → ' + segments.join(' • ');
        }

