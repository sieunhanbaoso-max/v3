            stopLiveAuto();

            var okDai = await ensureValidDaiBeforeAuto();
            if (!okDai) return;

            if (!canRunAutoLive()) {
                setStatus('warn', 'Auto chỉ chạy khi chọn ngày hôm nay, có chọn đài và bật Live mode.');
                return;
            }

            var okLoad = await loadData(true);
            if (!okLoad) {
                stopLiveAuto();
                return;
            }

            liveTimer = setInterval(async function () {
                if (document.hidden) return;

                if (!canRunAutoLive()) {
                    stopLiveAuto();
                    return;
                }

                var ok = await loadData(true);
                if (!ok) {
                    stopLiveAuto();
                }
            }, LIVE_INTERVAL_MS);

            setStatus('ok', 'Đã bật auto live. Hệ thống sẽ tự cập nhật mỗi 15 giây.');

        }

        function setStatus(type, msg) {
            var box = document.getElementById('status');
            box.className = 'status ' + type;
            box.textContent = msg || '';
        }

        function toArraySafe(v) {
            return Array.isArray(v) ? v : [];
        }

        function normalizeHoiDongArray(arr) {
            return toArraySafe(arr).map(function (x) {
                var raw = (x || '').replace(/\u00A0/g, ' ').trim();

                // Bỏ tiền tố đánh số kiểu: "1/", "2.", "3)", "03 -", ...
                raw = raw.replace(/^\s*0*\d{1,2}\s*([\/\.\)\-\:])\s*/, '').trim();

                // Bỏ luôn ký hiệu bullet đầu dòng nếu có.
                raw = raw.replace(/^[•\-]\s*/, '').trim();

                return raw;
            }).filter(function (x) {
                if (!x) return false;
                var compact = x.replace(/\s+/g, '');
                // Chỉ loại các token đánh số rác đứng độc lập, không loại nội dung tên thật.
                return !/^(0|3|03)$/.test(compact);
            });
        }

        function setValueIfExists(id, value) {
            var el = document.getElementById(id);
            if (el) el.value = value || '';
        }

        function setTextIfExists(id, value) {
            var el = document.getElementById(id);
            if (el) el.textContent = value || '';
        }

        function startOfWeekMonday(dt) {
            var d = new Date(dt.getFullYear(), dt.getMonth(), dt.getDate());
            var day = d.getDay(); // 0 = Sunday
            var diff = day === 0 ? -6 : (1 - day);
            d.setDate(d.getDate() + diff);
            d.setHours(0, 0, 0, 0);
            return d;
        }

        function dateToIsoLocal(dt) {
            var y = dt.getFullYear();
            var m = String(dt.getMonth() + 1).padStart(2, '0');
            var d = String(dt.getDate()).padStart(2, '0');
            return y + '-' + m + '-' + d;
        }

        function parseIsoToDate(iso) {
            var parts = String(iso || '').split('-');
            if (parts.length !== 3) return null;
            var y = parseInt(parts[0], 10);
            var m = parseInt(parts[1], 10);
            var d = parseInt(parts[2], 10);
            if (isNaN(y) || isNaN(m) || isNaN(d)) return null;
            var dt = new Date(y, m - 1, d);
            if (dt.getFullYear() !== y || dt.getMonth() !== m - 1 || dt.getDate() !== d) return null;
            dt.setHours(0, 0, 0, 0);
            return dt;
        }

        function normalizeNguoiLapIdx(idx) {
            var n = parseInt(idx, 10);
            if (isNaN(n)) n = 0;
            var mod = n % NGUOI_LAP_WEEKLY.length;
            return mod < 0 ? mod + NGUOI_LAP_WEEKLY.length : mod;
        }

        function loadNguoiLapBaseStateLocal() {
            try {
                var raw = localStorage.getItem(NGUOI_LAP_STATE_KEY);
                if (!raw) return 0;
                var state = JSON.parse(raw);
                if (!state) return 0;
                var savedIdx = normalizeNguoiLapIdx(state.baseIdx);
                var savedWeek = startOfWeekMonday(parseIsoToDate(state.weekStartIso) || new Date());
                var currentWeek = startOfWeekMonday(new Date());
                var weekMs = 7 * 24 * 60 * 60 * 1000;
                var weeksElapsed = Math.round((currentWeek.getTime() - savedWeek.getTime()) / weekMs);
                return normalizeNguoiLapIdx(savedIdx + weeksElapsed);
            } catch (e) {
                return 0;
            }
        }

        function saveNguoiLapBaseStateLocal(baseIdx) {
            try {
                var payload = {
                    baseIdx: normalizeNguoiLapIdx(baseIdx),
                    weekStartIso: dateToIsoLocal(startOfWeekMonday(new Date()))
                };
                localStorage.setItem(NGUOI_LAP_STATE_KEY, JSON.stringify(payload));
            } catch (e) {
                // ignore storage errors (private mode / disabled storage)
            }
        }

        async function loadNguoiLapBaseStateServer(dateIso) {
            var url = '@Url.Action("GetNguoiLapState", "MinhNgocRaw")' + '?date=' + encodeURIComponent(dateIso || getTodayIso());
            try {
                var resp = await fetch(url, { method: 'GET', cache: 'no-store' });
                if (!resp.ok) return null;
                var rs = await resp.json();
                if (!rs || rs.ok !== true) return null;
                nguoiLapStateVersion = parseInt(rs.version || '0', 10) || 0;
                if (Array.isArray(rs.list) && rs.list.length === 4) {
                    NGUOI_LAP_WEEKLY = rs.list.slice(0, 4);
                }
                return normalizeNguoiLapIdx(rs.baseIndexCurrentWeek);
            } catch (e) {
                return null;
            }
        }

        async function saveNguoiLapBaseStateServer(baseIdx) {
            var payload = new URLSearchParams();
            payload.set('baseIndex', String(normalizeNguoiLapIdx(baseIdx)));
            if (nguoiLapStateVersion > 0) payload.set('version', String(nguoiLapStateVersion));

            try {
                var resp = await fetch('@Url.Action("SetNguoiLapState", "MinhNgocRaw")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
                    body: payload.toString()
                });
                if (!resp.ok) return false;
                var rs = await resp.json();
                if (!rs || rs.ok !== true) {
                    if (rs && rs.conflict) {
                        setStatus('warn', rs.message || 'Có thay đổi từ máy khác, anh tải lại để đồng bộ.');
                    }
                    return false;
                }
                nguoiLapStateVersion = parseInt(rs.version || '0', 10) || nguoiLapStateVersion;
                return true;
            } catch (e) {
                return false;
            }
        }

        function getNguoiLapBaseIndex() {
            var sl = document.getElementById('nguoiLapBaseSelect');
