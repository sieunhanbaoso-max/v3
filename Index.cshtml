        @@page {
            size: A4 portrait;
            margin: 0;
        }

        .print-shell {
            width: 210mm;
            margin: 14px auto 0 auto;
            background: #fff;
            border: 1px solid #d8d8d8;
            padding: 0;
            overflow: hidden;
        }

        .print-area {
            width: 210mm;
            min-height: auto;
            height: auto;
            margin: 0;
            background: #fff;
            color: #000;
            font-family: "Times New Roman", Times, serif;
            padding-top: 1.10cm;
            padding-right: 2.007cm;
            padding-bottom: 0.432cm;
            padding-left: 2.997cm;
            box-sizing: border-box;
            overflow: visible;
            position: relative;
        }

        .header-table {
            width: 17.20cm;
            border-collapse: collapse;
            table-layout: fixed;
            margin: 0.25cm auto 1.5mm auto;
            border: none !important;
        }

            .header-table,
            .header-table tr,
            .header-table td {
                border: none !important;
            }

                .header-table td {
                    padding: 0;
                    height: 2.00cm;
                    text-align: center;
                    vertical-align: middle;
                }

        .header-left {
            width: 40%;
        }

        .header-right {
            width: 60%;
        }

        .header-left .header-box {
            width: 5.60cm;
            min-height: 2.00cm;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
        }

        .header-right .header-box {
            width: 8.40cm;
            min-height: 2.00cm;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
        }

        .header-left .line1,
        .header-left .line2,
        .header-right .line1,
        .header-right .line2 {
            font-family: "Times New Roman", Times, serif;
            font-size: 13pt;
            font-weight: 700;
            line-height: 1.03;
            white-space: nowrap;
            text-align: center;
            letter-spacing: -0.5pt;
            word-spacing: -1pt;
        }

        .header-left .line2,
        .header-right .line2 {
            margin-top: 1.2mm;
        }

        .header-left .underline {
            width: 3.2cm;
            border-bottom: 0.18mm solid #000;
            margin: 2.3mm auto 0 auto;
            height: 0;
        }

        .header-right .underline {
            width: 5.4cm;
            border-bottom: 0.18mm solid #000;
            margin: 2.3mm auto 0 auto;
            height: 0;
        }

        .title {
            text-align: center;
            margin-top: 4.12mm;
            margin-bottom: 2.12mm;
            font-family: "Times New Roman", Times, serif;
            font-size: 14pt;
            font-weight: 700;
            line-height: 1;
            white-space: nowrap;
        }

        .date-line {
            text-align: center;
            margin-top: 2.12mm;
            margin-bottom: 2.12mm;
            font-family: "Times New Roman", Times, serif;
            font-size: 14pt;
            font-weight: 700;
            line-height: 1;
            white-space: nowrap;
        }

        .print-counter {
            text-align: center;
            margin: 0 0 2.5mm 0;
            font-family: "Times New Roman", Times, serif;
            font-size: 14pt;
            font-weight: 700;
            letter-spacing: 2px;
            color: #111;
        }

            .print-counter.horse-mode {
                letter-spacing: 2px;
                font-size: 18pt;
                font-weight: 700;
                text-shadow: 0 1px 0 #fff, 0 0 10px rgba(168, 85, 247, 0.45);
            }

            .print-counter.horse-mode {
                letter-spacing: 2px;
                font-size: 18pt;
                font-weight: 700;
                text-shadow: 0 1px 0 #fff, 0 0 10px rgba(168, 85, 247, 0.45);
            }

            .print-counter.horse-mode {
                letter-spacing: 2px;
                font-size: 18pt;
                font-weight: 700;
                text-shadow: 0 1px 0 #fff, 0 0 10px rgba(168, 85, 247, 0.45);
            }

            .print-counter.horse-mode {
                letter-spacing: 2px;
                font-size: 18pt;
                font-weight: 700;
                text-shadow: 0 1px 0 #fff, 0 0 10px rgba(168, 85, 247, 0.45);
            }

            .print-counter.horse-mode {
                letter-spacing: 2px;
                font-size: 18pt;
                font-weight: 700;
                text-shadow: 0 1px 0 #fff, 0 0 10px rgba(168, 85, 247, 0.45);
            }

        .result-table {
            width: 16.53cm;
            border-collapse: collapse;
            table-layout: fixed;
            margin: 0.9cm auto;
        }

            .result-table col.col-prize {
                width: 4.83cm;
            }

            .result-table col.col-value {
                width: 11.70cm;
            }

            .result-table th,
            .result-table td {
                border: 0.18mm solid #000;
                padding: 0;
                text-align: center;
                vertical-align: middle;
            }

            .result-table thead th {
                font-family: "Times New Roman", Times, serif;
                font-size: 14pt;
                font-weight: 700;
                line-height: 1;
                padding-top: 2.1mm;
                padding-bottom: 2.1mm;
                white-space: nowrap;
            }

            .result-table td.prize {
                font-family: "Times New Roman", Times, serif;
                font-size: 14pt;
                font-weight: 400;
                line-height: 1;
                text-align: left;
                vertical-align: middle;
                white-space: nowrap;
                padding-top: 1.8mm;
                padding-bottom: 1.8mm;
                padding-left: 2.2mm;
                padding-right: 1mm;
            }

                .result-table td.prize.bold-prize,
                .result-table tr.db td.prize {
                    font-weight: 700;
                }

            .result-table td.value {
                font-family: "Times New Roman", Times, serif;
                font-size: 16pt;
                font-weight: 700;
                line-height: 1;
                text-align: center;
                vertical-align: middle;
                white-space: nowrap;
                padding-top: 1.5mm;
                padding-bottom: 1.5mm;
            }

        .print-empty {
            padding: 16px;
            text-align: center;
            color: #666;
            border: 1px dashed #ccc;
            font-family: Arial, Helvetica, sans-serif;
            margin: 6px;
        }

        .sign-table {
            width: 18.20cm;
            border-collapse: collapse;
            table-layout: fixed;
            margin: 0 auto 0 auto;
            position: relative;
            left: -0.90cm;
        }

            .sign-table td {
                border: none;
                padding: 0;
                text-align: center;
                vertical-align: top;
            }

            .sign-table col.c1,
            .sign-table col.c2,
            .sign-table col.c3,
            .sign-table col.c4 {
                width: 25%;
            }

        .sign-box {
            width: 4cm;
            margin: 0 auto 10mm;
            text-align: center;
        }

        .sign-title {
            font-family: "Times New Roman", Times, serif;
            font-size: 13pt;
            font-weight: 700;
            line-height: 1.05;
            white-space: nowrap;
        }

        .sign-sub {
            font-family: "Times New Roman", Times, serif;
            font-size: 14pt;
            line-height: 1.05;
            white-space: nowrap;
            margin-top: 1.4mm;
            font-weight: 700;
        }

            .sign-sub + .sign-sub {
                margin-top: 1.2mm;
            }

        .sign-name-row .sign-box {
            padding-top: 18mm;
