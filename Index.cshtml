        async function napDaiTheoNgay(showStatus) {
            var ngay = document.getElementById('ngay').value;
            if (!ngay) {
                setStatus('warn', 'Chưa chọn ngày.');
                return;
            }

            var oldDai = document.getElementById('dai').value;

            try {
                var url = '@Url.Action("GetDaiTheoNgay", "MinhNgocRaw")' + '?date=' + encodeURIComponent(ngay);
                var resp = await fetch(url, {
                    method: 'GET',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });

                var rs = await resp.json();

                if (!rs.ok) {
                    renderLich('', []);
                    renderDaiSelect([]);
                    stopLiveAuto();
                    if (showStatus) setStatus('err', rs.message || 'Không nạp được đài.');
                    return;
                }

                renderLich(rs.thu || '', rs.dais || []);
                renderDaiSelect(rs.dais || []);

                var daiSelect = document.getElementById('dai');
                if (oldDai && (rs.dais || []).indexOf(oldDai) >= 0) {
                    daiSelect.value = oldDai;
                } else {
                    var macDinh = getDefaultDaiForDate(ngay, rs.dais || []);
                    if (macDinh && (rs.dais || []).indexOf(macDinh) >= 0) {
                        daiSelect.value = macDinh;
                    }
                }

                if (showStatus) {
                    setStatus('ok', rs.message || 'Đã nạp đài theo ngày.');
                }

                if (!canRunAutoLive()) {
                    stopLiveAuto();
                }
            } catch (e) {
                renderLich('', []);
                renderDaiSelect([]);
                stopLiveAuto();
                if (showStatus) setStatus('err', 'Lỗi nạp đài: ' + e.message);
            }
        }

        function normalizeKeyClient(input) {
            if (!input) return '';
            var lower = input.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
            return lower.replace(/[^a-z0-9]+/g, '');
        }

        function cleanTextClient(input) {
            return (input || '').replace(/\u00A0/g, ' ').replace(/\s+/g, ' ').trim();
        }

        function digitsOnlyClient(input) {
            return (input || '').replace(/[^\d]/g, '');
        }

        function joinNumbersFromTdClient(td) {
            if (!td) return '';

            var html = td.innerHTML || '';
            html = html.replace(/<br\s*\/?>/gi, '|');
            html = html.replace(/<\/(div|p|li|span)>/gi, '|');
            html = html.replace(/<[^>]+>/g, ' ');

            var parts = html.split('|').map(cleanTextClient).filter(Boolean);
            var nums = parts.map(digitsOnlyClient).filter(Boolean);
            if (nums.length > 1) return nums.join(',');

            nums = [];
            Array.from(td.childNodes || []).forEach(function (n) {
                var t = cleanTextClient(n.textContent || '');
                var d = digitsOnlyClient(t);
                if (d) nums.push(d);
            });
            if (nums.length > 1) return nums.join(',');

            var text = cleanTextClient(td.textContent || '');
            var m = text.match(/\d+/g) || [];
            return m.join(',');
        }

        function buildMinhNgocUrlsClient(ngay) {
            var parts = (ngay || '').split('-');
            if (parts.length !== 3) return [];
            var slug = parts[2] + '-' + parts[1] + '-' + parts[0];
            var url1 = 'https://www.minhngoc.net/ket-qua-xo-so/mien-nam/' + slug + '.html';
