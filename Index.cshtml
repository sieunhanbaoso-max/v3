        function syncPendingCellsWithCounter() {
            if (!isLiveChecked()) return;
            var symbol = getCurrentRollingSymbol();
            document.querySelectorAll('#printBody td.value.pending').forEach(function (cell) {
                var raw = cell.getAttribute('data-raw-digits') || '';
                var digits = parseInt(cell.getAttribute('data-digits') || '0', 10);
                if (!digits) return;
                var need = Math.max(0, digits - raw.length);
                cell.textContent = raw + symbol.repeat(need);
            });
        }

        function buildRows(record) {
            if (!record) return [];

            var schema = [
                { key: 'G8', giai: 'Giải Tám', count: 1, digits: 2, isDb: false },
                { key: 'G7', giai: 'Giải Bảy', count: 1, digits: 3, isDb: false },
                { key: 'G6', giai: 'Giải Sáu', count: 3, digits: 4, isDb: false },
                { key: 'G5', giai: 'Giải Năm', count: 1, digits: 4, isDb: false },
                { key: 'G4', giai: 'Giải Tư', count: 7, digits: 5, isDb: false },
                { key: 'G3', giai: 'Giải Ba', count: 2, digits: 5, isDb: false },
                { key: 'G2', giai: 'Giải Nhì', count: 1, digits: 5, isDb: false },
                { key: 'G1', giai: 'Giải Nhất', count: 1, digits: 5, isDb: false },
                { key: 'DB', giai: 'Giải Đặc Biệt', count: 1, digits: 6, isDb: true }
            ];

            var rows = [];

            toArraySafe(schema).forEach(function (cfg) {
                var vals = splitValsSafe(record[cfg.key]);

                for (var i = 0; i < cfg.count; i++) {
                    var v = vals[i] || '';
                    var digitsOnly = String(v).replace(/\D/g, '');
                    var isPending = digitsOnly.length < cfg.digits;
                    rows.push({
                        giai: cfg.giai,
                        val: !isPending ? v : makePendingText(cfg.digits),
                        rawVal: v,
                        digits: cfg.digits,
                        isDb: cfg.isDb,
                        pending: isPending
                    });
                }
            });

            return rows;

        }

