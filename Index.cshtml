            var d = parseInt(parts[2], 10);
            if (isNaN(y) || isNaN(m) || isNaN(d)) return '';
            var dt = new Date(y, m - 1, d);
            var map = {
                1: ['hcm', 'hochiminh'],               // Thứ 2
                2: ['vungtau'],                        // Thứ 3
                3: ['dongnai', 'dong', 'nai'],         // Thứ 4
                4: ['tayninh'],                        // Thứ 5
                5: ['binhduong'],                      // Thứ 6
                6: ['hcm', 'hochiminh'],               // Thứ 7
                0: ['dalat', 'lat']                    // Chủ nhật
            };
            var wantedKeys = map[dt.getDay()] || [];
            if (!wantedKeys.length) return '';

            var arr = toArraySafe(dais);
            for (var i = 0; i < arr.length; i++) {
                var key = normalizeKeyClient(arr[i]);
                var hit = wantedKeys.some(function (k) { return key.indexOf(k) >= 0; });
