        async function loadData(isAuto) {
            var ngay = document.getElementById('ngay').value;
            var dai = document.getElementById('dai').value;

            if (isLoadingData) return;

            if (!ngay) {
                setStatus('warn', 'Chưa chọn ngày.');
                return;
            }

            if (!dai) {
                setStatus('warn', 'Chưa chọn đài.');
                return;
            }

            if (!isCurrentDaiValidForSelectedDate()) {
                stopLiveAuto();
                currentParsedRecord = null;
                clearPrintTable();
                setStatus('warn', 'Đài chọn không đúng lịch của ngày này. Đã dừng, không lấy dữ liệu.');
                toastMsg('warn', 'Đài chọn không đúng lịch của ngày này. Đã dừng, không lấy dữ liệu.');
                return false;
            }

            isLoadingData = true;

            if (!isAuto) {
                clearAll();
                setStatus('ok', 'Đang tải dữ liệu...');
            } else {
                setStatus('ok', 'Đang tự cập nhật kết quả trực tiếp...');
            }

            try {
                var url = '@Url.Action("Load", "MinhNgocRaw")'
                    + '?date=' + encodeURIComponent(ngay)
                    + '&dai=' + encodeURIComponent(dai);

                var resp = await fetch(url, {
                    method: 'GET',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });

                var rs = await resp.json();

                if ((rs.daiHopLeTheoThu === true) && (!rs.ok || !rs.record)) {
                    var rsClient = await tryLoadClientDirectFromMinhNgoc(ngay, dai, rs);
                    if (rsClient && rsClient.ok) {
                        rs = rsClient;
                    }
                }

                if ((rs.daiHopLeTheoThu === true) && (!rs.ok || !rs.record)) {
                    var rsClient = await tryLoadClientDirectFromMinhNgoc(ngay, dai, rs);
                    if (rsClient && rsClient.ok) {
                        rs = rsClient;
                    }
                }

                if ((rs.daiHopLeTheoThu === true) && (!rs.ok || !rs.record)) {
                    var rsClient = await tryLoadClientDirectFromMinhNgoc(ngay, dai, rs);
                    if (rsClient && rsClient.ok) {
                        rs = rsClient;
                    }
                }

                if ((rs.daiHopLeTheoThu === true) && (!rs.ok || !rs.record)) {
                    var rsClient = await tryLoadClientDirectFromMinhNgoc(ngay, dai, rs);
                    if (rsClient && rsClient.ok) {
                        rs = rsClient;
                    }
                }

                if ((rs.daiHopLeTheoThu === true) && (!rs.ok || !rs.record)) {
                    var rsClient = await tryLoadClientDirectFromMinhNgoc(ngay, dai, rs);
                    if (rsClient && rsClient.ok) {
                        rs = rsClient;
                    }
                }

                setValueIfExists('urlBox', rs.url || '');
                setValueIfExists('textBox', rs.text || '');
                setValueIfExists('htmlBox', rs.html || '');

                var frame = document.getElementById('previewFrame');
                if (frame) frame.srcdoc = rs.html || '';

                renderLich(rs.thu || '', rs.dais || []);

                if (rs.daiHopLeTheoThu !== true) {
                    stopLiveAuto();

                    var chk = document.getElementById('chkLiveMode');
                    if (chk) chk.checked = false;

                    currentParsedRecord = null;
                    clearPrintTable();

                    setStatus('warn', rs.message || 'Đài chọn không đúng lịch của ngày này. Đã dừng tuyệt đối.');
                    toastMsg('warn', rs.message || 'Đài chọn không đúng lịch của ngày này. Đã dừng tuyệt đối.');

                    return false;
                }

                if (!rs.ok) {
                    currentParsedRecord = null;
                    clearPrintTable();
                    setStatus('err', rs.message || 'Không tải được dữ liệu.');
                    return false;
                }

                ///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
                if (!rs.daiHopLeTheoThu) {
                    stopLiveAuto();
                    currentParsedRecord = null;
                    clearPrintTable();

                    var chk = document.getElementById('chkLiveMode');
                    if (chk) chk.checked = false;

                    setStatus('warn', rs.message || 'Đài chọn không đúng lịch của ngày này.');
                    toastMsg('warn', rs.message || 'Đài chọn không đúng lịch của ngày này.');
                    return false;
                }

                ///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

                currentParsedRecord = rs.record || null;

                if (!currentParsedRecord) {
                    var pendingRecord = buildPendingRecord(dai);
                    renderPrintTable(pendingRecord, ngay);
                    setStatus('warn', rs.message || 'Đã tải HTML, đang chờ kết quả trực tiếp...');
                    return false;
                }

                setStatus('ok', isAuto ? 'Đã tự cập nhật kết quả trực tiếp.' : 'Đã tải xong kết quả.');
                renderPrintTable(currentParsedRecord, ngay);
                if (isAuto) {
                    tryAutoPrintIfReady(currentParsedRecord, ngay, dai);
                }
                return true;

            } catch (e) {
                currentParsedRecord = null;
                clearPrintTable();
                console.error('loadData error =', e);
                setStatus('err', 'Lỗi khi gọi màn load: ' + e.message);
            } finally {
                isLoadingData = false;
            }
        }

