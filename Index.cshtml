        function toLoTo4(value) {
            var s = (value || '').trim();
            if (!s) return '';
            if (s.length >= 4) return s.slice(-4);
            return s;
        }

        function transformRowsForLoTo(rows) {
            var result = [];

            toArraySafe(rows).forEach(function (r) {
                var loto = toLoTo4(r.val);
                var rawLoto = toLoTo4(r.rawVal || '');
                var digits = Math.min(4, r.digits || 4);
                var pending = !!r.pending;

                if (loto || pending) {
                    result.push({
                        giai: r.giai,
                        val: pending ? makePendingText(digits) : loto,
                        rawVal: rawLoto,
                        digits: digits,
                        pending: pending,
                        isDb: r.isDb
                    });
                }
            });

            return result;

        }

        function renderPrintTable(record, ngay) {
            if (!record) {
                clearPrintTable();
                return;
            }

            setTextIfExists('printDaiHeader', record.Dai || 'Đài');

            if (ngay) {
                var parts = ngay.split('-');
                if (parts.length === 3) {
                    setTextIfExists('printDateLine', 'Ngày ' + parts[2] + ' tháng ' + parts[1] + ' năm ' + parts[0]);
                }
            }

            var rows = buildRows(record);
            if (isLoTo4Mode()) {
                rows = transformRowsForLoTo(rows);
            }

            var body = document.getElementById('printBody');
            body.innerHTML = '';

            if (!rows.length) {
                body.innerHTML = '<tr><td colspan="2"><div class="print-empty">Không có dữ liệu để hiển thị.</div></td></tr>';
                return;
            }

            rows.forEach(function (r) {
                var tr = document.createElement('tr');
                if (r.isDb) tr.className = 'db';

                var td1 = document.createElement('td');
                td1.className = 'prize' + (r.isDb ? ' bold-prize' : '');
                td1.textContent = r.giai;

                //var td2 = document.createElement('td');
                //td2.className = 'value';
                //td2.textContent = r.val;

                var td2 = document.createElement('td');
                td2.className = 'value' + (r.pending ? ' pending' : '');
                var displayVal = r.val;
                if (r.pending) {
                    var rawDigits = String(r.rawVal || '').replace(/\D/g, '');
                    var need = Math.max(0, (r.digits || 0) - rawDigits.length);
                    td2.setAttribute('data-raw-digits', rawDigits);
                    td2.setAttribute('data-digits', String(r.digits || 0));
                    if (isLiveChecked()) {
                        var symbol = getCurrentRollingSymbol();
                        displayVal = rawDigits + symbol.repeat(need);
                    } else {
                        displayVal = rawDigits + makePendingText(need);
                    }
                } else {
                    td2.removeAttribute('data-raw-digits');
                    td2.removeAttribute('data-digits');
                }
                td2.textContent = displayVal;

                tr.appendChild(td1);
                tr.appendChild(td2);
                body.appendChild(tr);
            });
        }

