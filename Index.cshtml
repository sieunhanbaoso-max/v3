        function resolveNguoiLapNameByDate(dateIso) {
            var baseIdx = getNguoiLapBaseIndex();
            if (!dateIso) return NGUOI_LAP_WEEKLY[baseIdx] || NGUOI_LAP_WEEKLY[0];

            var parts = String(dateIso).split('-');
            if (parts.length !== 3) return NGUOI_LAP_WEEKLY[baseIdx] || NGUOI_LAP_WEEKLY[0];

            var y = parseInt(parts[0], 10);
            var m = parseInt(parts[1], 10);
            var d = parseInt(parts[2], 10);
            if (isNaN(y) || isNaN(m) || isNaN(d)) return NGUOI_LAP_WEEKLY[baseIdx] || NGUOI_LAP_WEEKLY[0];

            var target = new Date(y, m - 1, d);
            var now = new Date();
            var targetWeek = startOfWeekMonday(target);
            var currentWeek = startOfWeekMonday(now);
            var weekMs = 7 * 24 * 60 * 60 * 1000;
            var weekOffset = Math.round((targetWeek.getTime() - currentWeek.getTime()) / weekMs);
            var idx = (baseIdx + weekOffset) % NGUOI_LAP_WEEKLY.length;
            if (idx < 0) idx += NGUOI_LAP_WEEKLY.length;
            return NGUOI_LAP_WEEKLY[idx];
        }

