        function resizeMatrixCanvas() {
            var canvas = document.getElementById('matrixCanvas');
            if (!canvas) return;
            var dpr = window.devicePixelRatio || 1;
            canvas.width = Math.floor(window.innerWidth * dpr);
            canvas.height = Math.floor(window.innerHeight * dpr);

            matrixCtx = canvas.getContext('2d');
            if (!matrixCtx) return;
            matrixCtx.setTransform(dpr, 0, 0, dpr, 0, 0);
            matrixCols = Math.ceil(window.innerWidth / matrixFontSize);
            matrixDrops = Array.from({ length: matrixCols }, function () {
                return Math.random() * window.innerHeight / matrixFontSize;
            });
        }

        function drawMatrixFrame() {
            if (!matrixThemeOn || !matrixCtx) return;

            var w = window.innerWidth;
            var h = window.innerHeight;
            matrixCtx.fillStyle = 'rgba(1, 11, 10, 0.08)';
            matrixCtx.fillRect(0, 0, w, h);

            matrixCtx.font = matrixFontSize + 'px monospace';
            for (var i = 0; i < matrixDrops.length; i++) {
                var text = matrixChars.charAt(Math.floor(Math.random() * matrixChars.length));
                var x = i * matrixFontSize;
                var y = matrixDrops[i] * matrixFontSize;

                matrixCtx.fillStyle = Math.random() > 0.93 ? '#b8ffe9' : '#49ffc8';
                matrixCtx.fillText(text, x, y);

                if (y > h && Math.random() > 0.975) {
                    matrixDrops[i] = 0;
                } else {
                    matrixDrops[i] += 1;
                }
            }

            matrixAnimFrame = window.requestAnimationFrame(drawMatrixFrame);
        }

        function startMatrixRain() {
            if (matrixAnimFrame) return;
            resizeMatrixCanvas();
            drawMatrixFrame();
        }

        function stopMatrixRain() {
            if (matrixAnimFrame) {
                window.cancelAnimationFrame(matrixAnimFrame);
                matrixAnimFrame = null;
            }
            if (matrixCtx) {
                matrixCtx.clearRect(0, 0, window.innerWidth, window.innerHeight);
            }
        }

        function normalizeBldName(name) {
            var raw = (name || '').trim();
            if (!raw) return '';

            var cleaned = raw
                .replace(/^Đ\/c\s*/i, '')
                .replace(/^ĐC\s*/i, '')
                .trim();

            var key = cleaned.toLowerCase();

            if (key === 'đức' || key === 'duc') return 'Nguyễn Công Đức';
            if (key === 'giống' || key === 'giong') return 'Phan Hữu Giống';
            if (key === 'tiến' || key === 'tien') return 'Đinh Việt Tiến';
            if (key === 'thư' || key === 'thu') return 'Lê Anh Thư';
            return cleaned;
        }

        function normalizeBldArray(arr) {
            return (arr || []).map(function (x) {
                return normalizeBldName(x);
            }).filter(function (x) {
                return !!x;
            });
        }

        function isLiveMode() {
            return document.getElementById('ngay').value === getTodayIso();
        }

