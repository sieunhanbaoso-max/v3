        function printOnlyResultArea() {
            if (!currentParsedRecord) {
                setStatus('warn', 'Chưa có dữ liệu để in. Anh bấm Load dữ liệu trước.');
                return;
            }

            var printShell = document.querySelector('.print-shell');
            if (!printShell) {
                setStatus('err', 'Không tìm thấy vùng in.');
                return;
            }

            document.body.classList.add('direct-print-mode');

            var cleaned = false;
            function cleanupAfterPrint() {
                if (cleaned) return;
                cleaned = true;
                document.body.classList.remove('direct-print-mode');
                window.removeEventListener('afterprint', cleanupAfterPrint);
            }

            window.addEventListener('afterprint', cleanupAfterPrint);
            setTimeout(cleanupAfterPrint, 1500);
            window.print();
        }

        async function ensureValidDaiBeforeAuto() {
            document.getElementById('ngay').value = getTodayIso();
            await napDaiTheoNgay(false);

            var daiSelect = document.getElementById('dai');
            if (!daiSelect) {
                setStatus('err', 'Không tìm thấy ô chọn đài.');
                toastMsg('err', 'Không tìm thấy ô chọn đài.');
                return false;
            }

            var currentValue = daiSelect.value || '';

            var validDais = Array.from(daiSelect.options)
                .slice(1)
                .map(function (o) { return o.value; })
                .filter(function (v) { return !!v; });

            if (validDais.length === 0) {
                setStatus('warn', 'Ngày này chưa có đài hợp lệ để chạy auto.');
                toastMsg('warn', 'Ngày này chưa có đài hợp lệ để chạy auto.');
                return false;
            }

            if (!currentValue) {
                setStatus('warn', 'Chưa chọn đài. Anh chọn đài đúng lịch rồi bấm lại.');
                toastMsg('warn', 'Chưa chọn đài. Anh chọn đài đúng lịch rồi bấm lại.');
                return false;
            }

            if (validDais.indexOf(currentValue) < 0) {

                setStatus('warn', 'Đài chọn không đúng lịch của ngày này. Auto đã dừng, không lấy dữ liệu.');
                toastMsg('warn', 'Đài chọn không đúng lịch của ngày này. Auto đã dừng, không lấy dữ liệu.');
                return false;
            }

            return true;
        }

        function isCurrentDaiValidForSelectedDate() {
            var daiSelect = document.getElementById('dai');
            if (!daiSelect) return false;

            var currentValue = daiSelect.value || '';
            if (!currentValue) return false;

            var validDais = Array.from(daiSelect.options)
                .slice(1) // bỏ option đầu "-- Chọn đài --"
                .map(function (o) { return o.value; })
                .filter(function (v) { return !!v; });

            return validDais.indexOf(currentValue) >= 0;
        }





